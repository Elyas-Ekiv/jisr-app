# =============================================================================
# Jisr — Docker / Dokploy environment variables
# =============================================================================
# Copy this file to `.env` in the project root before running:
#   cp .env.example .env
#
# Start the full stack:
#   docker compose up -d --build
#
# First deploy only (seed admin + demo data):
#   RUN_SEED=true docker compose up -d --build
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose — ports & database
# -----------------------------------------------------------------------------

FRONTEND_PORT=80
BACKEND_PORT=3000
VITE_API_URL=/api

POSTGRES_USER=jisr
POSTGRES_PASSWORD=change-me-use-a-long-random-password
POSTGRES_DB=jisr_db

RUN_SEED=false

# -----------------------------------------------------------------------------
# Application URLs (required in production)
# -----------------------------------------------------------------------------

FRONTEND_URL=https://your-domain.com
PUBLIC_BASE_URL=https://your-domain.com
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# Backend server
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=3000
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880

# -----------------------------------------------------------------------------
# JWT authentication (required in production)
# -----------------------------------------------------------------------------

JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Thawani payment gateway (required in production)
# -----------------------------------------------------------------------------

THAWANI_API_KEY=
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om
THAWANI_MODE=test

# -----------------------------------------------------------------------------
# Email — Resend (optional)
# -----------------------------------------------------------------------------

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Jisr

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_PAYMENT_MAX_REQUESTS=10
